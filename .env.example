# Per-user, local only: copy to `.env`, put your real keys after the = sign, never commit.
# For HTTP MCP in Cursor/Claude, put Base64-encoded values in `mcp.json` `headers` (see README).
# `.env` is for running the server locally (plain values; not Base64-encoded in the file).
# dev.to: https://dev.to/settings/extensions → DEV Community API Keys
DEVTO_API_KEY=

# Hashnode GraphQL API: https://docs.hashnode.com/quickstart/introduction
# PAT: https://hashnode.com/settings/developer
HASHNODE_TOKEN=
# Your blog hostname, e.g. myblog.hashnode.dev or your custom domain
HASHNODE_PUBLICATION_HOST=

# Optional: stdio (default) or http (Streamable HTTP for Cursor URL mode)
# MCP_TRANSPORT=stdio
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=8765
# On a VM or Docker, bind all interfaces: MCP_HTTP_HOST=0.0.0.0

# Optional HTTP timeouts (seconds)
# MCP_HTTP_TIMEOUT=30.0
